                    },
                    "401": {
                        "$ref": "#\/components\/responses\/AuthenticationException"
                    }
                }
            }
        },
        "\/requests\/{requestM}\/reject": {
            "post": {
                "operationId": "requestM.reject",
                "summary": "POST \/api\/requests\/{id}\/reject",
                "tags": [
                    "RequestM"
                ],
                "parameters": [
                    {
                        "name": "requestM",
                        "in": "path",
                        "required": true,
                        "description": "The request m ID",
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "`RequestResource`",
                        "content": {
                            "application\/json": {
                                "schema": {
