                        }
                    },
                    "403": {
                        "$ref": "#\/components\/responses\/AuthorizationException"
                    },
                    "404": {
                        "$ref": "#\/components\/responses\/ModelNotFoundException"
                    },
                    "401": {
                        "$ref": "#\/components\/responses\/AuthenticationException"
                    }
                }
            },
            "put": {
                "operationId": "requestM.update",
                "summary": "PUT \/api\/requests\/{id}",
                "tags": [
                    "RequestM"
                ],
                "parameters": [
                    {
                        "name": "requestM",
                        "in": "path",
                        "required": true,
                        "description": "The request m ID",
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart\/form-data": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/SolicitudRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "`RequestResource`",
                        "content": {
                            "application\/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#\/components\/schemas\/RequestResource"
                                        }
                                    },
                                    "required": [
                                        "data"
                                    ]
                                }
                            }
                        }
                    },
                    "403": {
                        "$ref": "#\/components\/responses\/AuthorizationException"
                    },
                    "404": {
                        "$ref": "#\/components\/responses\/ModelNotFoundException"
                    },
                    "401": {
                        "$ref": "#\/components\/responses\/AuthenticationException"
                    },
                    "422": {
                        "$ref": "#\/components\/responses\/ValidationException"
                    }
                }
            }
        },
        "\/requests\/{requestM}\/signature": {
            "post": {
                "operationId": "requestM.signature",
                "summary": "POST \/api\/requests\/{id}\/signature",
                "tags": [
                    "RequestM"
                ],
                "parameters": [
                    {
                        "name": "requestM",
                        "in": "path",
                        "required": true,
                        "description": "The request m ID",
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application\/json": {
                            "schema": {
                                "$ref": "#\/components\/schemas\/SignatureRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "`RequestResource`",
                        "content": {
                            "application\/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#\/components\/schemas\/RequestResource"
                                        }
                                    },
                                    "required": [
                                        "data"
                                    ]
                                }
                            }
                        }
                    },
                    "403": {
                        "$ref": "#\/components\/responses\/AuthorizationException"
                    },
                    "404": {
                        "$ref": "#\/components\/responses\/ModelNotFoundException"
                    },
                    "401": {
                        "$ref": "#\/components\/responses\/AuthenticationException"
                    },
                    "422": {
                        "$ref": "#\/components\/responses\/ValidationException"
                    }
                }
            }
        },
        "\/requests\/{requestM}\/approve": {
            "post": {
                "operationId": "requestM.approve",
                "summary": "POST \/api\/requests\/{id}\/approve",
                "tags": [
                    "RequestM"
                ],
                "parameters": [
                    {
                        "name": "requestM",
                        "in": "path",
                        "required": true,
                        "description": "The request m ID",
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "`RequestResource`",
                        "content": {
                            "application\/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#\/components\/schemas\/RequestResource"
                                        }
